# Database (SQLite for dev; switch to MongoDB in prisma/schema.prisma)
DATABASE_URL=file:./db/custom.db

# MongoDB Atlas (production) — set provider="mongodb" in prisma/schema.prisma
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.mongodb.net/playbeat?appName=APP

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# OAuth providers (optional — fill to enable Google/Facebook login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Admin bootstrap: first signup with this email becomes admin
ADMIN_BOOTSTRAP_EMAIL=admin@playbeat.live

# JazzCash (Pakistan payments)
JAZZCASH_SANDBOX=true
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=
JAZZCASH_RETURN_URL=https://playbeat.digital/api/payments/jazzcash/return

# EasyPaisa (manual payment)
EASYPAISA_NUMBER=03390005715
NEXT_PUBLIC_EASYPAISA_NUMBER=03390005715

# Stripe (international cards)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# PayPal (international)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_SANDBOX=true

# Bot handler (30s health/sync)
BOT_HANDLER_SECRET=generate-a-random-secret

# AdSense
# (ads.txt is in /public/ads.txt)
