// Prisma schema for PLAYBEAT TV — MongoDB Atlas

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // ⚠️ MongoDB auth failing — see instructions below.
  // Once you fix the Atlas credentials, change provider to "mongodb".
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid()) @map("_id")
  email         String    @unique
  name          String?
  password      String? // hashed (credentials provider)
  image         String?
  role          String    @default("user") // "user" | "admin"
  plan          String    @default("free") // "free" | "monthly" | "quarterly" | "yearly"
  planExpires   DateTime?
  region        String    @default("PK") // ISO country code for region-wise pricing
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  favorites     Favorite[]
  history       History[]
  subscriptions Subscription[]
  payments      Payment[]
}

model Account {
  id                String  @id @default(cuid()) @map("_id")
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid()) @map("_id")
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(cuid()) @map("_id")
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Shared IPTV backend config (admin-managed). Only one active row.
model Playlist {
  id         String   @id @default(cuid()) @map("_id")
  name       String
  dns        String
  username   String
  password   String
  active     Boolean  @default(false)
  status     String   @default("unknown")
  expires    String?
  userInfo   String?
  serverInfo String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// Custom meta-categories that map to Xtream backend categories.
model CustomCategory {
  id          String   @id @default(cuid()) @map("_id")
  slug        String   @unique // "news" | "sports" | "movies" ...
  name        String
  icon        String?  // lucide icon name
  color       String?  // tailwind gradient
  sort        Int      @default(0)
  // JSON array of patterns matched against Xtream category names (case-insensitive)
  patterns    String   @default("[]")
  createdAt   DateTime @default(now())
}

model Favorite {
  id         String   @id @default(cuid()) @map("_id")
  streamId   String
  name       String
  type       String // "live" | "movie" | "series"
  categoryId String?
  logo       String?
  streamUrl  String
  userId     String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([streamId, type, userId])
}

model History {
  id         String   @id @default(cuid()) @map("_id")
  streamId   String
  name       String
  type       String
  logo       String?
  streamUrl  String
  progress   Int      @default(0)
  duration   Int      @default(0)
  userId     String
  watchedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([streamId, type, userId])
}

model Subscription {
  id        String   @id @default(cuid()) @map("_id")
  userId    String
  plan      String // "monthly" | "quarterly" | "yearly"
  amount    Float
  currency  String   @default("USD")
  region    String   @default("PK")
  status    String   @default("active") // "active" | "cancelled" | "expired" | "pending"
  startAt   DateTime @default(now())
  endAt     DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Payment records for JazzCash / Stripe / PayPal / EasyPaisa
model Payment {
  id           String   @id @default(cuid()) @map("_id")
  userId       String
  gateway      String   // "jazzcash" | "easypaisa" | "stripe" | "paypal" | "manual"
  amount       Float
  currency     String   @default("PKR")
  plan         String
  txnRef       String?  // JazzCash pp_TxnRefNo / Stripe session / PayPal order
  status       String   @default("pending") // "pending" | "paid" | "failed" | "refunded"
  gatewayData  String?  // JSON blob of gateway response
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
