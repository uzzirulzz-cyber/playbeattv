// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Playlist {
  id        String   @id @default(cuid())
  name      String
  dns       String
  username  String
  password  String
  active    Boolean  @default(false)
  status    String   @default("unknown") // "online" | "offline" | "unknown"
  expires   String?
  userInfo  String?
  serverInfo String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  favorites Favorite[]
  history   History[]
}

model Favorite {
  id         String   @id @default(cuid())
  streamId   String
  name       String
  type       String   // "live" | "movie" | "series"
  categoryId String?
  logo       String?
  streamUrl  String
  playlistId String
  createdAt  DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@unique([streamId, type, playlistId])
}

model History {
  id         String   @id @default(cuid())
  streamId   String
  name       String
  type       String   // "live" | "movie" | "series"
  logo       String?
  streamUrl  String
  progress   Int      @default(0) // seconds
  duration   Int      @default(0) // seconds
  playlistId String
  watchedAt  DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@unique([streamId, type, playlistId])
}
