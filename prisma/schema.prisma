// Prisma schema for PLAYBEAT TV

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String? // hashed (credentials provider)
  image         String?
  role          String    @default("user") // "user" | "admin"
  plan          String    @default("free") // "free" | "monthly" | "quarterly" | "yearly"
  planExpires   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  favorites     Favorite[]
  history       History[]
  subscriptions Subscription[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Shared IPTV backend config (admin-managed). Only one active row.
model Playlist {
  id         String   @id @default(cuid())
  name       String
  dns        String
  username   String
  password   String
  active     Boolean  @default(false)
  status     String   @default("unknown")
  expires    String?
  userInfo   String?
  serverInfo String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Favorite {
  id         String   @id @default(cuid())
  streamId   String
  name       String
  type       String // "live" | "movie" | "series"
  categoryId String?
  logo       String?
  streamUrl  String
  userId     String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([streamId, type, userId])
}

model History {
  id         String   @id @default(cuid())
  streamId   String
  name       String
  type       String
  logo       String?
  streamUrl  String
  progress   Int      @default(0)
  duration   Int      @default(0)
  userId     String
  watchedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([streamId, type, userId])
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  plan      String // "monthly" | "quarterly" | "yearly"
  amount    Float
  currency  String   @default("USD")
  status    String   @default("active") // "active" | "cancelled" | "expired"
  startAt   DateTime @default(now())
  endAt     DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
