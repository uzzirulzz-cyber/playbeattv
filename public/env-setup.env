# ============================================================
# PlayBeat TV — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Get this file: https://playbeat.live/env-setup.env
# ============================================================

# ---- Database (SQLite for dev) ----
DATABASE_URL=file:./db/custom.db

# ---- MongoDB Atlas (production) ----
# To enable: in prisma/schema.prisma change provider to "mongodb"
# Create the database user in Atlas Dashboard → Database Access
MONGODB_URI=mongodb+srv://playbeatdigitalxx:playbeat1122@ghar.ahbfod0.mongodb.net/playbeat?appName=ghar

# ---- NextAuth ----
NEXTAUTH_URL=http://localhost:3000
# Generate new secret: openssl rand -base64 32
NEXTAUTH_SECRET=L8obsM1ZC6mxvHgPYcvhmBdR5F5vuQ4uUPm0fB7H3U8=

# ---- Admin Bootstrap ----
# First user to sign up with this email becomes admin
ADMIN_BOOTSTRAP_EMAIL=admin@playbeat.live

# ---- Google OAuth ----
# Get from: https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Facebook OAuth ----
# Get from: https://developers.facebook.com/apps
# Redirect URI: http://localhost:3000/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ---- JazzCash (Pakistan payments) ----
# Sandbox creds provided; set JAZZCASH_SANDBOX=false for production
JAZZCASH_SANDBOX=true
JAZZCASH_MERCHANT_ID=MC828933
JAZZCASH_PASSWORD=t3zz48w4aa
JAZZCASH_INTEGRITY_SALT=tdw4713y34
JAZZCASH_RETURN_URL=https://playbeat.digital/api/payments/jazzcash/return

# ---- EasyPaisa (manual payment) ----
EASYPAISA_NUMBER=03390005715
NEXT_PUBLIC_EASYPAISA_NUMBER=03390005715

# ---- Stripe (international cards) ----
# Get from: https://dashboard.stripe.com/apikeys
# Test keys: sk_test_... / pk_test_...
# Live keys: sk_live_... / pk_live_...
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# ---- PayPal (international) ----
# Get from: https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_SANDBOX=true

# ---- Bot Handler (30s health/sync) ----
# Generate new secret: openssl rand -hex 16
BOT_HANDLER_SECRET=playbeat-bot-2026

